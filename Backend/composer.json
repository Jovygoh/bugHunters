{
    "name": "bughunters/backend",
    "type": "project",
    "description": "BugHunters AegisAI Backend API",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "policy": {
            "advisories": {
                "block": false
            }
        },
        "audit": {
            "block": false,
            "abandoned": "ignore"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}